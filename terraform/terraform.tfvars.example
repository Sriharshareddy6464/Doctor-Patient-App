# AWS Region Configuration
aws_region  = "us-east-1"
environment = "v2"

# VPC CIDR (10.1.0.0/16 used to avoid overlap with 10.0.0.0/16)
vpc_cidr                 = "10.1.0.0/16"
public_subnet_cidrs      = ["10.1.1.0/24", "10.1.2.0/24"]
private_app_subnet_cidrs = ["10.1.3.0/24", "10.1.4.0/24"]
private_db_subnet_cidrs  = ["10.1.5.0/24", "10.1.6.0/24"]

# Security & Access (Replace with your IP address)
admin_ip = "203.0.113.5/32"
# ssh_public_key = "ssh-rsa AAAAB3Nza..." # Optional: Terraform automatically generates docco-v2-key.pem locally

# Compute Sizing (Free Tier Eligible)
instance_type = "t3.micro"

# Database Configuration
db_name     = "docco360"
db_user     = "docco_db_user"
db_password = "V2_StrongProductionPassword123!"

# Optional SSL & Custom Domain
domain_name = "docco.arakutravels.com"
enable_ssl  = false
